# dependencies
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Expo (mobile)
apps/mobile/.expo/
apps/mobile/expo-env.d.ts
apps/mobile/web-build/

# dist
apps/mobile/dist/
apps/desktop/dist/
packages/*/dist/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Tauri (desktop)
apps/desktop/src-tauri/target/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
apps/mobile/ios/
apps/mobile/android/
